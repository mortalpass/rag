# ==========================
# 1. 通用目录与文件
# ==========================
# 忽略操作系统生成的杂项文件
.DS_Store
Thumbs.db

# ==========================
# 2. 依赖目录
# ==========================
# Node.js 依赖
node_modules/
# Python 虚拟环境
venv/
env/
.venv/

# ==========================
# 3. 构建与分发目录 (生成文件，不需要关心)
# ==========================
dist/
build/
out/
.next/
target/

# ==========================
# 4. 缓存文件
# ==========================
__pycache__/
*.pyc
.cache/
.parcel-cache/

# ==========================
# 5. 敏感信息与环境变量 (绝对要忽略！)
# ==========================
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# ==========================
# 6. 日志文件
# ==========================
*.log
npm-debug.log*
logs/

# ==========================
# 7. 测试与代码覆盖率报告
# ==========================
coverage/
.nyc_output/
.pytest_cache/
__snapshots__/

# ==========================
# 8. IDE 及编辑器配置 (习惯团队统一约定)
# ==========================
.vscode/
.idea/

# ==========================
# 9. 大型数据文件 (占用大量 Token，通常无益)
# ==========================
*.csv
*.parquet
*.db
*.sqlite
datasets/